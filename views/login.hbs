<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/footer.css">
    <title>Login</title>
</head>

<body>

    {{>navbar}}

    <h1 class="text-2xl flex justify-center align-baseline mt-20 m-auto py-4 lg:w-1/3 md:w-5/12 sm:w-1/2 bg-orange-600 text-white">Login and Order Now</h1>

    <!-- component -->
    <form action="/login" method="post">
        <div class="bg-white shadow-md rounded px-8 pt-6 pb-8 lg:w-1/2 md:w-1/2 sm:w-3/4 mx-auto my-10 flex flex-col">
            <div class="mb-4">
                <label class="block text-grey-darker text-sm font-bold mb-2" for="email">
                    Email
                </label>
                <input class="shadow appearance-none border rounded w-full py-2 px-3 text-grey-darker" id="email"
                    type="email" placeholder="email" name="email" required>
            </div>
            <div class="mb-6">
                <label class="block text-grey-darker text-sm font-bold mb-2" for="password">
                    Password
                </label>
                <input class="shadow appearance-none border border-red rounded w-full py-2 px-3 text-grey-darker mb-3"
                    id="password" type="password" placeholder="******************" name="password" required>
                <p class="text-red text-xs italic">Please choose a password.</p>
            </div>
            <div class="flex items-center justify-between">
                <button class="border-2 border-orange-600 bg-orange-600 hover:bg-white text-white hover:text-orange-600 font-bold py-2 px-4 rounded" type="submit">
                    Log In
                </button>
                <a class="inline-block align-baseline font-bold text-sm text-blue hover:text-blue-darker" href="#">
                    Forgot Password?
                </a>
            </div>
        </div>
    </form>
    
    <div class="rounded lg:w-1/2 md:w-1/2 sm:w-3/4 mx-auto my-10 flex flex-wrap justify-center align-center text-center">
        <p class="m-2">New to FoodExpress?</p>
        <a href="/register" class="m-2 flex justify-center font-bold text-xl text-blue hover:text-blue-darker text-orange-600">Sign Up</a>
    </div>

    {{>footer}}

</body>

</html>